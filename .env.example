# X API OAuth 2.0 user access token with tweet.write permission.
# Do not commit a real token.
X_USER_ACCESS_TOKEN=
X_REFRESH_TOKEN=
X_CLIENT_ID=
X_CLIENT_SECRET=

# Optional market and analytics sources for the Founder Board.
TARGET_X_HANDLES=gregisenberg,noahkagan,george__mack,buildinpublic,openai,perplexity_ai,AnthropicAI
REDDIT_SUBREDDITS=SaaS,startups,Entrepreneur,SideProject,indiehackers
REDDIT_SEARCH_QUERIES=solo founder,build in public,SaaS metrics,AI agents startup,distribution
PLAUSIBLE_API_KEY=
PLAUSIBLE_SITE_ID=
PLAUSIBLE_HOST=https://plausible.io
POSTHOG_PERSONAL_API_KEY=
POSTHOG_PROJECT_ID=
POSTHOG_HOST=https://us.posthog.com

# Optional. Dry run is enabled unless explicitly set to false.
DRY_RUN=true

# Web approval dashboard.
ADMIN_PASSWORD=change-this-password
SESSION_SECRET=change-this-long-random-secret

# Optional token for posting drafts into the queue through POST /api/items.
API_TOKEN=change-this-api-token

# Optional. Use a persistent disk/volume path in production.
# Render example: /var/data/queue.json
# Railway volume example: /data/queue.json
QUEUE_PATH=content/queue.json

# Optional. When greater than 0, the web app checks and publishes approved
# items on this interval. Keep this conservative.
PUBLISH_INTERVAL_MINUTES=15
